# KugelAudio Configuration
KUGELAUDIO_API_KEY=your_api_key_here
KUGELAUDIO_API_URL=https://api.kugelaudio.com/v1
# Optional: pin a default voice via UI; leave unset to use the SDK default voice.
# KUGELAUDIO_VOICE_ID=977
# KUGELAUDIO_MODEL_ID=kugel-2

# LiveKit (for the WebRTC voice-agent path — Phase 2 of the demo)
# Create a free project at https://cloud.livekit.io and paste the values:
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# IBM watsonx Orchestrate Configuration
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_URL=https://eu-de.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your_project_id

# Optional: fine-tuned deployment ids — set after `npm run tune:<scenario>`
# and creating a deployment in watsonx Studio. If set, the server routes that
# scenario through the deployment instead of the base foundation model.
WATSONX_DEPLOYMENT_ID_CLAIMS=
WATSONX_DEPLOYMENT_ID_HOTLINE=

# Required only for `npm run tune:*` — COS connection inside the watsonx project.
COS_CONNECTION_ID=
COS_BUCKET=
TUNE_BASE_MODEL=ibm/granite-3-8b-instruct

# Salesforce Integration (optional)
SALESFORCE_CLIENT_ID=your_sf_client_id
SALESFORCE_CLIENT_SECRET=your_sf_client_secret
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com

# Server Configuration
PORT=3000
NODE_ENV=development
# Optional local HTTPS (recommended for browser microphone permissions)
# LOCAL_HTTPS=true
# LOCAL_HTTPS_CERT_PATH=.cert/localhost-cert.pem
# LOCAL_HTTPS_KEY_PATH=.cert/localhost-key.pem

# Logging
LOG_LEVEL=info
